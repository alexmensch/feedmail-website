<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.name }} — {{ site.description }}{% endif %}</title>
    <meta name="description" content="{{ summary | default: site.description }}" />
    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
    <meta property="og:title" content="{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.name }}{% endif %}" />
    <meta property="og:description" content="{{ summary | default: site.description }}" />
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <link rel="stylesheet" href="/assets/css/main.css" />
  </head>
  <body>
    {{ content }}
  </body>
</html>
